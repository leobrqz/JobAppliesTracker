# Supavisor transaction pooler (self-hosted Supabase)
DATABASE_URL=postgresql://postgres.{POOLER_TENANT_ID}:{POSTGRES_PASSWORD}@host.docker.internal:6543/postgres?sslmode=disable
APP_ENV=development

# Kong URL reachable from backend container
SUPABASE_URL=http://host.docker.internal:8000
# Optional (used as API key for backend -> auth calls when needed)
SUPABASE_ANON_KEY=
# Copy SERVICE_ROLE_KEY from supabase/.env
SUPABASE_SERVICE_ROLE_KEY=
# Create this bucket in Supabase Studio (private)
SUPABASE_STORAGE_BUCKET=jobtracker
SUPABASE_JWT_VERIFICATION_MODE=hs256
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
# Recommended in all environments and required in production (APP_ENV=production).
# Self-hosted defaults often use `supabase`.
SUPABASE_JWT_ISSUER=
AUTH_PUBLIC_PATHS=/,/healthz,/openapi.json,/docs,/docs/oauth2-redirect,/redoc

# Must match frontend origin
CORS_ORIGINS=http://localhost:3000
