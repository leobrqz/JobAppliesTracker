# Supavisor transaction pooler (self-hosted Supabase)
DATABASE_URL=postgresql://postgres.{POOLER_TENANT_ID}:{POSTGRES_PASSWORD}@host.docker.internal:6543/postgres

# Kong URL reachable from backend container
SUPABASE_URL=http://host.docker.internal:8000
# Copy SERVICE_ROLE_KEY from supabase/.env
SUPABASE_SERVICE_ROLE_KEY=
# Create this bucket in Supabase Studio (private)
SUPABASE_STORAGE_BUCKET=jobtracker

# Must match frontend origin
CORS_ORIGINS=http://localhost:3000
